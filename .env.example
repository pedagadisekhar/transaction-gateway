# Docker Environment Configuration Template
# Copy this to .env and adjust values as needed

# PostgreSQL Configuration
POSTGRES_DB=swiftpay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=2208
POSTGRES_VERSION=16

# Redis Configuration
REDIS_VERSION=7

# Kafka Configuration
KAFKA_VERSION=7.5.0
ZOOKEEPER_VERSION=7.5.0

# Spring Boot Application Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/swiftpay
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# Application Port
APP_PORT=8080

# Logging Level
LOGGING_LEVEL=INFO
